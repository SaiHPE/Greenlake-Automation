# Copy this to a file named ".env" in the directory you run `onboard` from
# (it is gitignored). Or run `onboard configure` to write it interactively.
#
# These are HPE GreenLake "personal API client" credentials
# (Manage Workspace -> Personal API clients -> Create personal API client).

GL_CLIENT_ID=your-client-id
GL_CLIENT_SECRET=your-client-secret

# Per-workspace token URL shown next to the API client. NOTE: this is the
# newer authorization/v2 endpoint, NOT sso.common.cloud.hpe.com.
GL_TOKEN_URL=https://global.api.greenlake.hpe.com/authorization/v2/oauth2/<workspace-tenant-id>/token

GL_BASE_URL=https://global.api.greenlake.hpe.com
GL_MEMBER_WORKSPACE_ID=<workspace-tenant-id>
